        .task-btn:hover { background-color: rgba(50, 50, 50, 0.8); }
        .task-btn i.fa-tiktok { color: #ff0050; }
        
        .task-btn.completed {
            background-color: rgba(46, 204, 113, 0.2);
            border-color: #2ecc71;
            color: #2ecc71;
            cursor: default;
        }

        #key-reveal-box {
            display: none;
            background: rgba(46, 204, 113, 0.15);
            border: 1px dashed #2ecc71;
            padding: 15px;
            border-radius: 15px;
            margin-bottom: 20px;
            animation: fadeIn 0.5s ease;
