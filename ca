<body>

    <div class="cat-container">
        <div class="ear left"><div class="ear-inner"></div></div>
        <div class="ear right"><div class="ear-inner"></div></div>
        <div class="head">
            <div class="eyes">
                <div class="eye"><div class="pupil"></div></div>
                <div class="eye"><div class="pupil"></div></div>
            </div>
            <div class="nose"></div>
            <div class="mouth-area">
                <div class="mouth-line"></div>
                <div class="mouth" id="catMouth"></div>
            </div>
        </div>
    </div>

    <div class="controls">
        <button id="setupBtn">Tap to Start</button>
        <button id="micBtn">🎤</button>
        <div id="statusText"></div>
    </div>

    <script>
        const INTRO_TEXT = "Namaste, ma Sangam lay create gareko app ho. Malai use garna, yo mic ma hold gari rakhnu parxa, ani tapai ko hand mic bata hataye pachi, ma hajur ko voice repeat garxu.";
        const PITCH_SPEED = 1.35;

        // Audio Variables
        let audioContext;
        let mediaStream;
        let mediaRecorder;
        let audioChunks = [];
        let isRecording = false;
        let isTomSpeaking = false;
        let synth = window.speechSynthesis;
        let introAnimationInterval;

        // Elements
        const setupBtn = document.getElementById('setupBtn');
        const micBtn = document.getElementById('micBtn');
        const statusText = document.getElementById('statusText');
        const mouth = document.getElementById('catMouth');

        // --- 1. START & INTRO LOGIC ---
        setupBtn.addEventListener('click', async () => {
            try {
                // Initialize Audio Context (Standard Browser Requirement)
                audioContext = new (window.AudioContext || window.webkitAudioContext)();
                
                // Get Mic Permission early
                mediaStream = await navigator.mediaDevices.getUserMedia({ audio: true });
                
                // Hide Start Button
                setupBtn.style.display = 'none';
                
                // Play Intro Message
                playIntroMessage();

            } catch (err) {
                alert("Microphone permission denied! I cannot hear you.");
                console.error(err);
            }
        });

        function playIntroMessage() {
            statusText.innerText = "Sangam's Cat is speaking...";
            statusText.style.color = "#006400";
            
            const utter = new SpeechSynthesisUtterance(INTRO_TEXT);
            
            // Try to set a voice that sounds okay-ish (Hindi/Nepali prefered if installed)
            // Browsers usually default to English robot if Nepali isn't found.
            const voices = synth.getVoices();
            // Try finding a Hindi voice for better accent, otherwise default
            const preferredVoice = voices.find(v => v.lang.includes('hi') || v.lang.includes('ne'));
            if(preferredVoice) utter.voice = preferredVoice;

            utter.pitch = 1.2; // Little bit higher pitch
            utter.rate = 0.9;  // Speak slowly

            // ANIMATION START
            utter.onstart = () => {
                isTomSpeaking = true;
                // Fake mouth animation for TTS (Robot voice doesn't give volume data)
                introAnimationInterval = setInterval(() => {
                    const randomHeight = Math.floor(Math.random() * 20) + 5;
                    mouth.style.height = randomHeight + 'px';
                    mouth.classList.add('talking');
                }, 100);
            };

            // ANIMATION END
            utter.onend = () => {
                clearInterval(introAnimationInterval);
                mouth.style.height = '2px';
                mouth.classList.remove('talking');
                isTomSpeaking = false;
                
                // Show the Mic Button now
                micBtn.style.display = 'flex';
                statusText.innerText = "Hold button to speak!";
                statusText.style.color = "#333";
            };

            synth.speak(utter);
        }


        // --- 2. PUSH TO TALK LOGIC (Same as before) ---

        // Mouse (Desktop)
        micBtn.addEventListener('mousedown', startRecording);
        window.addEventListener('mouseup', stopRecording);

        // Touch (Mobile)
        micBtn.addEventListener('touchstart', (e) => {
            e.preventDefault(); 
            startRecording();
        });
        window.addEventListener('touchend', stopRecording);

        function startRecording() {
            if (!mediaStream || isRecording || isTomSpeaking) return;

            micBtn.classList.add('pressed');
            statusText.innerText = "Listening... 🔴";
            statusText.style.color = "red";
            
            audioChunks = [];
            mediaRecorder = new MediaRecorder(mediaStream);
            
            mediaRecorder.ondataavailable = event => {
                audioChunks.push(event.data);
            };

            mediaRecorder.start();
            isRecording = true;
        }

        function stopRecording() {
            if (!isRecording) return;

            micBtn.classList.remove('pressed');
            statusText.innerText = "Processing...";
            statusText.style.color = "#333";

            mediaRecorder.stop();
            isRecording = false;

            mediaRecorder.onstop = async () => {
                const blob = new Blob(audioChunks, { type: 'audio/webm' });
                if (blob.size < 500) { // Ignore accidental clicks
                    statusText.innerText = "Hold button to speak!";
                    return;
                }

                const arrayBuffer = await blob.arrayBuffer();
                const audioBuffer = await audioContext.decodeAudioData(arrayBuffer);
                playAsCat(audioBuffer);
            };
        }

        // --- 3. PLAYBACK (High Pitch) ---
        function playAsCat(buffer) {
            isTomSpeaking = true;
            statusText.innerText = "Repeating... 🔊";
            statusText.style.color = "green";

            const source = audioContext.createBufferSource();
            source.buffer = buffer;
            source.playbackRate.value = PITCH_SPEED;

            const analyser = audioContext.createAnalyser();
            analyser.fftSize = 256;

            source.connect(analyser);
            analyser.connect(audioContext.destination);

            source.start(0);
            animateMouthRealtime(analyser); // Use Real volume for this part

            source.onended = () => {
                isTomSpeaking = false;
                mouth.style.height = '2px';
                mouth.classList.remove('talking');
                statusText.innerText = "Hold button to speak!";
                statusText.style.color = "#333";
            };
        }

        function animateMouthRealtime(analyserNode) {
            if (!isTomSpeaking) return;
            const dataArray = new Uint8Array(analyserNode.frequencyBinCount);
            analyserNode.getByteFrequencyData(dataArray);
            
            let sum = 0;
            for(let i = 0; i < dataArray.length; i++) sum += dataArray[i];
            let avg = sum / dataArray.length;

            let height = 5 + (avg / 2); 
            mouth.style.height = height + 'px';
            mouth.classList.add('talking');
            requestAnimationFrame(() => animateMouthRealtime(analyserNode));
        }

    </script>
</body>
