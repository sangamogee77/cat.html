    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@400;500;700;800&display=swap" rel="stylesheet">
    <!-- Font Awesome for Icons -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
            font-family: 'Poppins', sans-serif;
            -webkit-tap-highlight-color: transparent;
        }

        body {
            background-color: #000;
            color: #fff;
            display: flex;
            justify-content: center;
            align-items: center;
            min-height: 100vh;
            overflow-x: hidden;
            position: relative;
        }

        /* --- BACKGROUND ANIMATION CANVAS --- */
        #network-canvas {
            position: fixed;
            top: 0;
            left: 0;
            width: 100vw;
            height: 100vh;
            z-index: 0;
            pointer-events: none;
        }

        /* Main Container */
        .container {
            width: 100%;
            max-width: 420px;
            padding: 20px;
            z-index: 10;
            position: relative;
        }

        /* Glassmorphism Effect */
        .glass-panel {
            background: rgba(15, 15, 15, 0.6);
            backdrop-filter: blur(12px);
            -webkit-backdrop-filter: blur(12px);
            border: 1px solid rgba(255, 255, 255, 0.08);
            box-shadow: 0 8px 32px 0 rgba(0, 0, 0, 0.8);
        }

        /* --- LOGIN SCREEN STYLES --- */
        #login-screen {
            padding: 50px 30px;
            border-radius: 30px;
            text-align: center;
            animation: fadeIn 0.5s ease;
        }

        .title {
            font-size: 2.2rem;
            font-weight: 800;
            letter-spacing: 1px;
            margin-bottom: 5px;
            text-shadow: 0 0 10px rgba(255,255,255,0.2);
        }

        .subtitle {
            font-size: 0.7rem;
            letter-spacing: 4px;
            color: #aaa;
            margin-bottom: 40px;
            text-transform: uppercase;
        }

        input[type="password"], input[type="text"] {
            width: 100%;
            background-color: rgba(0, 0, 0, 0.5);
            border: 1px solid rgba(255, 255, 255, 0.2);
            color: #fff;
            padding: 18px;
            border-radius: 15px;
            text-align: center;
            font-size: 1.5rem;
            letter-spacing: 8px;
            margin-bottom: 20px;
            outline: none;
            transition: 0.3s;
        }

        input[type="password"]:focus, input[type="text"]:focus {
            border-color: #3498db;
            box-shadow: 0 0 15px rgba(52, 152, 219, 0.3);
        }

        button.btn-primary {
            width: 100%;
            background: linear-gradient(45deg, #ffffff, #dcdcdc);
            color: #000;
            border: none;
            padding: 18px;
            border-radius: 15px;
            font-size: 1rem;
            font-weight: 700;
            letter-spacing: 2px;
            cursor: pointer;
            transition: all 0.3s ease;
            box-shadow: 0 5px 15px rgba(255, 255, 255, 0.2);
        }

        button.btn-primary:hover {
            transform: translateY(-2px);
            box-shadow: 0 8px 20px rgba(255, 255, 255, 0.3);
        }

        button.btn-primary:active {
            transform: translateY(1px);
        }

        .error-msg {
            color: #ff4757;
            font-size: 0.85rem;
            margin-top: 15px;
            height: 20px;
            font-weight: 500;
        }

        /* --- MAIN APP SCREEN STYLES --- */
        #app-screen {
            display: none;
            animation: slideUpFade 0.6s ease;
            min-height: 95vh;
            border-radius: 30px;
            padding-bottom: 30px;
            margin-top: 15px;
            margin-bottom: 15px;
        }

        .header {
            text-align: center;
            padding: 40px 0 30px 0;
        }

        .tool-list {
            display: flex;
            flex-direction: column;
            gap: 15px;
            padding: 0 10px;
        }

        .tool-card {
            display: flex;
            align-items: center;
            background-color: rgba(20, 20, 20, 0.7);
            padding: 18px 25px;
            border-radius: 20px;
            text-decoration: none;
            color: #fff;
            transition: all 0.3s cubic-bezier(0.25, 0.8, 0.25, 1);
            border: 1px solid rgba(255, 255, 255, 0.05);
            position: relative;
            overflow: hidden;
            cursor: pointer;
        }

        .tool-card::before {
            content: '';
            position: absolute;
            top: 0; left: -100%;
            width: 50%; height: 100%;
            background: linear-gradient(90deg, transparent, rgba(255,255,255,0.05), transparent);
            transition: 0.5s;
        }

        .tool-card:hover::before {
            left: 100%;
        }

        .tool-card:hover {
            background-color: rgba(40, 40, 40, 0.8);
            transform: scale(1.03);
            border-color: rgba(255, 255, 255, 0.2);
            box-shadow: 0 10px 20px rgba(0,0,0,0.6);
            z-index: 2;
        }

        /* Locked item style */
        .locked-card {
            border: 1px solid rgba(255, 71, 87, 0.3);
        }
        .locked-card .tool-arrow {
            color: #ff4757;
        }
        .locked-card:hover .tool-arrow {
            color: #ff6b81;
        }

        .tool-icon {
            font-size: 1.3rem;
            width: 40px;
            text-align: left;
            text-shadow: 0 0 10px currentColor;
        }

        .tool-name {
            flex-grow: 1;
            font-size: 0.95rem;
            font-weight: 500;
            color: #f1f2f6;
            letter-spacing: 0.5px;
        }

        .tool-arrow {
            color: #555;
            font-size: 0.9rem;
            transition: 0.3s;
        }

        .tool-card:hover .tool-arrow {
            color: #fff;
            transform: translateX(4px);
        }

        /* Footer */
        .footer {
            text-align: center;
            margin-top: 40px;
            font-size: 0.7rem;
            color: #777;
            letter-spacing: 2px;
            text-transform: uppercase;
        }

        .dev-info {
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 15px;
            margin-top: 10px;
            font-size: 0.9rem;
            letter-spacing: 1px;
        }

        .dev-name {
            color: #fff;
            font-weight: 700;
            background: linear-gradient(90deg, #3498db, #9b59b6);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
        }

        .social-links a {
            color: #aaa;
            font-size: 1.3rem;
            text-decoration: none;
            transition: 0.3s;
            margin: 0 5px;
            display: inline-flex;
            align-items: center;
            justify-content: center;
        }

        .social-links a:hover {
            color: #fff;
            transform: scale(1.2) translateY(-2px);
            text-shadow: 0 0 10px rgba(255,255,255,0.5);
        }

        /* --- TASK MODAL STYLES --- */
        .modal-overlay {
            position: fixed;
            top: 0; left: 0; width: 100vw; height: 100vh;
            background: rgba(0,0,0,0.85);
            z-index: 1000;
            display: none;
            justify-content: center;
            align-items: center;
            backdrop-filter: blur(8px);
            -webkit-backdrop-filter: blur(8px);
            animation: fadeIn 0.3s ease;
        }

        .modal-content {
            width: 90%;
            max-width: 380px;
            padding: 30px 20px;
            border-radius: 25px;
            position: relative;
            text-align: center;
            animation: slideUpFade 0.4s ease;
        }

        .close-btn {
            position: absolute;
            top: 15px; right: 20px;
            font-size: 1.5rem;
            color: #aaa;
            cursor: pointer;
            transition: 0.3s;
        }
        .close-btn:hover { color: #fff; transform: scale(1.1); }

        .modal-title {
            font-size: 1.4rem;
            font-weight: 700;
            margin-bottom: 5px;
            color: #fff;
        }

        .modal-desc {
            font-size: 0.8rem;
            color: #aaa;
            margin-bottom: 20px;
        }

        .task-list {
            display: flex;
            flex-direction: column;
            gap: 10px;
            margin-bottom: 20px;
        }

        .task-btn {
            background-color: rgba(30, 30, 30, 0.8);
            border: 1px solid rgba(255, 255, 255, 0.1);
            color: #fff;
            padding: 12px 15px;
            border-radius: 12px;
            font-size: 0.9rem;
            display: flex;
            align-items: center;
            justify-content: space-between;
